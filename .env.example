# Sentinel Environment Configuration
# Copy this to .env and fill in your values

# API Security
SENTINEL_API_KEY=your-secure-api-key-here

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Broker Credentials (alternative to credentials.json)
# KITE_API_KEY=
# KITE_ACCESS_TOKEN=
# DHAN_CLIENT_ID=
# DHAN_ACCESS_TOKEN=
# DELTA_API_KEY=
# DELTA_API_SECRET=
# DELTA_TESTNET=true
